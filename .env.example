# MIMO-TTS Legado Bridge - Environment Variables
# Copy this file to .env and fill in the values

# Required: MIMO-TTS API configuration
API_BASE_URL=https://api.xiaomimimo.com/v1
API_KEY=your_mimo_api_key_here

# Required: Basic Auth credentials for Legado login
# Users will need to enter these in Legado's login prompt
USERNAME=your_username
PASSWORD=your_password

# Optional: TTS configuration
MODEL=mimo-v2.5-tts
DEFAULT_VOICE=晓晓
DEFAULT_STYLE=温柔，语速适中
TIMEOUT_SECS=60
MAX_TEXT_LENGTH=5000
OUTPUT_FORMAT=wav

# Optional: Server configuration
RATE_LIMIT_PER_MINUTE=60
MAX_REQUEST_SIZE=1048576
LOG_LEVEL=info
