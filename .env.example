# MIMO-TTS API 配置（必填）
MIMO_TTS_API_KEY=your_api_key_here

# API 基础地址（默认即可）
MIMO_TTS_API_BASE_URL=https://api.xiaomimimo.com/v1

# 模型名称（默认 mimo-v2.5-tts）
# 可选值：mimo-v2.5-tts / mimo-v2.5-tts-voicedesign / mimo-v2.5-tts-voiceclone
MIMO_TTS_MODEL=mimo-v2.5-tts

# 默认音色（可选）：晓晓/晓伊/云阳/云逸/Mia/Chloe/Milo/Dean
MIMO_TTS_DEFAULT_VOICE=晓晓

# 默认风格指令（可选）
MIMO_TTS_DEFAULT_STYLE=温柔，语速适中

# 请求超时时间（秒）
MIMO_TTS_TIMEOUT=60

# 单次最大文本长度（超过此长度将自动分段合成）
MIMO_TTS_MAX_TEXT_LENGTH=5000

# 输出音频格式（wav/mp3，mp3 需要安装 ffmpeg）
OUTPUT_AUDIO_FORMAT=wav

# 服务监听地址和端口
SERVER_HOST=0.0.0.0
SERVER_PORT=9880

# CORS 允许的来源（逗号分隔，生产环境请设置具体域名）
CORS_ORIGINS=http://localhost:9880

# 服务 API 密钥（留空则不启用认证，生产环境强烈建议设置）
API_KEY=

# 速率限制（如 60/minute, 100/hour）
RATE_LIMIT=60/minute

# 最大请求体大小（字节），默认 1MB
MAX_REQUEST_SIZE=1048576

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO
